# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000
API_VERSION=v1
BASE_PATH=/api

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/rate-limiter
MONGODB_POOL_SIZE=10
MONGODB_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_DELAY_MS=1000

# Security
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_COOKIE_MAX_AGE=604800000
JWT_COOKIE_SECURE=false
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=lax

# Plan Limits (requests per minute)
FREE_LIMIT=20
PREMIUM_LIMIT=200
ADMIN_LIMIT=Infinity

# Rate Limiting
RATE_WINDOW_SECONDS=60
AUTH_WINDOW_SECONDS=900
AUTH_MAX_ATTEMPTS=5
GENERAL_MAX_REQUESTS=100
ADMIN_MAX_REQUESTS=1000
RETRY_AFTER_SECONDS=60

# Cache Configuration
DASHBOARD_CACHE_TTL=10
TOP_USERS_CACHE_TTL=10
ADMIN_STATS_CACHE_TTL=30
REDIS_KEY_TTL=60

# Security Settings
BCRYPT_ROUNDS=10
SESSION_TIMEOUT_SECONDS=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900
PASSWORD_MIN_LENGTH=6

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_ANALYTICS=true
ENABLE_ADMIN_ROUTES=true
ENABLE_HTTPS=false
ENABLE_DEBUG=false
ENABLE_COMPRESSION=true
ENABLE_LOGGING=true

# Logging
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILE_SIZE=10m
LOG_MAX_FILES=5

# API Messages
RATE_LIMIT_MESSAGE=Too Many Requests
AUTH_ERROR_MESSAGE=Invalid credentials
SERVER_ERROR_MESSAGE=Internal Server Error
NOT_FOUND_MESSAGE=Resource not found